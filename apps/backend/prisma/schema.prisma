generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  nome      String
  cpf       String
  senha     String
  tipo      String
  setor     String
  dtCriacao DateTime @default(now())

  ativo       Boolean  @default(true)

  criadoPorId Int?
  criadoPor   Usuario? @relation("Criador", fields: [criadoPorId], references: [id])

  usuariosCriados Usuario[] @relation("Criador")

  publicacoes Publicacao[]
  links        Link[]
  atendimentosCeSu UsuarioCeSu[] @relation("AtendimentoCeSu")
}

model Indicador {
  id      Int    @id @default(autoincrement())
  nome    String @unique
  classe  String
  setor   String

  valores IndicadorValor[]
}

model IndicadorValor {
  id          Int       @id @default(autoincrement())
  dados       Json   
  data        DateTime  @default(now()) 
  
  indicadorId Int
  indicador   Indicador @relation(fields: [indicadorId], references: [id])
}


model Setores {
  id       Int    @id @default(autoincrement())
  nome     String
  subsetor String?
  ramal    String?
}

model Publicacao {
  id          Int      @id @default(autoincrement())
  tipo        String //(Manual, Atualizações, Tutoriais, Publicações )
  titulo      String
  descricao   String
  texto       String
  pdfUrl      String?
  dtCriacao   DateTime @default(now())

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
}

model Link {
  id            Int      @id @default(autoincrement())

  nome          String
  tipo          String   // "link" | "pdf"

  url           String   // link externo ou arquivo

  pasta         String   // pasta principal
  subpasta      String?  // opcional

  dtCriacao     DateTime @default(now())

  usuarioId     Int
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])
}

model UsuarioCeSu {
  id                 Int       @id @default(autoincrement())
  nomeCompleto       String
  ramalTelefone      String
  email              String
  setor              String
  descricao          String?
  horarioAbertura    DateTime  @default(now())
  horarioAtendimento DateTime?
  
  usuarioAtendimentoId Int?
  usuarioAtendimento   Usuario? @relation("AtendimentoCeSu", fields: [usuarioAtendimentoId], references: [id])

  resolvido          String?
}
